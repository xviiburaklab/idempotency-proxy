PORT=3000
UPSTREAM_URL=http://localhost:4000  # point this at whatever you want to protect
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://idem:idem@localhost:5432/idempotency
TTL_SECONDS=86400    # 24h, change if you need shorter/longer
LOCK_TTL_SECONDS=30  # should be longer than your slowest upstream response
LOG_LEVEL=info
